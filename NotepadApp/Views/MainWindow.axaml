<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NotepadApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="NotepadApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="NotepadApp">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="toolbar" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <Button Content="Export" Command="{Binding ExportToTextCommand}"/>
                <Separator/>
                <ComboBox ItemsSource="{Binding Notepads}" 
                          SelectedItem="{Binding CurrentNotepad}" 
                          Width="150">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Title}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="+" Command="{Binding AddNewNotepadCommand}" Width="30"/>
                <Separator/>
                <CheckBox Content="Auto Save" IsChecked="{Binding AutoSave}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="{Binding TasksWidth}" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Notes Section -->
            <Border Grid.Column="0" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Notes" FontWeight="Bold" Margin="8"/>
                    <ScrollViewer Grid.Row="1" Margin="8">
                        <TextBox Text="{Binding CurrentNotepad.FreeformNotes}" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>

            <!-- Tasks Section -->
            <Border Grid.Column="2" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Tasks" FontWeight="Bold" Margin="8"/>
                    
                    <!-- Add Task -->
                    <Grid Grid.Row="1" Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewTaskText}" 
                                 Watermark="Add new task..."/>
                        <Button Grid.Column="1" Content="Add" 
                                Command="{Binding AddTaskCommand}"
                                Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Search and Filter -->
                    <Grid Grid.Row="2" Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SearchText}" 
                                 Watermark="Search tasks..."/>
                        <CheckBox Grid.Column="1" Content="Show Done" 
                                  IsChecked="{Binding ShowCompleted}"
                                  Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Tasks List -->
                    <ScrollViewer Grid.Row="3" Margin="8">
                        <ItemsControl ItemsSource="{Binding FilteredTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="task-item" Margin="2" Padding="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding Done}"
                                                      Command="{Binding $parent[Window].DataContext.ToggleTaskCommand}"
                                                      CommandParameter="{Binding}"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Text}" 
                                                       VerticalAlignment="Center"
                                                       Margin="8,0"
                                                       TextDecorations="{Binding Done, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                            <Button Grid.Column="2" 
                                                    Content="×" 
                                                    Command="{Binding $parent[Window].DataContext.DeleteTaskCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="20" Height="20"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Task Actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="8" Spacing="8">
                        <Button Content="Clear Done" Command="{Binding ClearCompletedTasksCommand}"/>
                        <Button Content="Sort" Command="{Binding SortTasksCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
